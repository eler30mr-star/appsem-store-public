rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "ceo.developer.appsem@gmail.com";
    }

    function appRef(appId) {
      return /databases/$(database)/documents/apps/$(appId);
    }

    function parentAppPublished(appId) {
      return get(appRef(appId)).data.status == "published";
    }

    function changedOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    function updateTimeIsServerTime() {
      return request.resource.data.updatedAt == request.time;
    }

    function publicLikeIncrement() {
      return changedOnly(["likesCount", "updatedAt"])
        && request.resource.data.likesCount == resource.data.likesCount + 1
        && updateTimeIsServerTime();
    }

    function publicDownloadIncrement() {
      return changedOnly(["downloadsCount", "updatedAt"])
        && request.resource.data.downloadsCount == resource.data.downloadsCount + 1
        && updateTimeIsServerTime();
    }

    function publicRatingUpdate() {
      return changedOnly(["ratingAverage", "ratingCount", "updatedAt"])
        && request.resource.data.ratingCount == resource.data.ratingCount + 1
        && request.resource.data.ratingAverage is number
        && request.resource.data.ratingAverage >= 1
        && request.resource.data.ratingAverage <= 5
        && updateTimeIsServerTime();
    }

    match /apps/{appId} {
      allow read: if resource.data.status == "published" || isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (resource.data.status == "published" && (
          publicLikeIncrement() ||
          publicDownloadIncrement() ||
          publicRatingUpdate()
        ));

      match /likes/{likeId} {
        allow read: if isAdmin() || parentAppPublished(appId);
        allow create: if parentAppPublished(appId)
          && request.resource.data.keys().hasOnly(["createdAt"])
          && request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }

      match /ratings/{ratingId} {
        allow read: if isAdmin() || parentAppPublished(appId);
        allow create: if parentAppPublished(appId)
          && request.resource.data.keys().hasOnly(["rating", "createdAt"])
          && request.resource.data.rating is number
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }

      match /downloadClicks/{clickId} {
        allow read: if isAdmin();
        allow create: if parentAppPublished(appId)
          && request.resource.data.keys().hasOnly(["targetUrl", "createdAt"])
          && request.resource.data.targetUrl is string
          && request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }

      match /comments/{commentId} {
        allow read: if isAdmin() || (
          parentAppPublished(appId)
          && resource.data.approved == true
        );
        allow create: if parentAppPublished(appId)
          && request.resource.data.keys().hasOnly(["name", "comment", "approved", "createdAt"])
          && request.resource.data.name is string
          && request.resource.data.name.size() >= 2
          && request.resource.data.name.size() <= 60
          && request.resource.data.comment is string
          && request.resource.data.comment.size() >= 5
          && request.resource.data.comment.size() <= 800
          && request.resource.data.approved == false
          && request.resource.data.createdAt == request.time;
        allow update, delete: if isAdmin();
      }
    }
  }
}
